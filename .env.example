# --- Firebase configuratie ---
# Kopieer dit bestand naar `.env` en vul je eigen Firebase-waarden in.
# Je vindt deze in de Firebase Console > Project settings > "Your apps" (Web app).
# Zonder deze waarden draait de app automatisch in DEMO-modus (lokale mock data).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Optioneel ---
# GitHub Pages base path (alleen nodig bij `npm run build`).
# Standaard is dit '/WereldReiziger/'. De GitHub Action vult dit automatisch.
# VITE_BASE=/WereldReiziger/

